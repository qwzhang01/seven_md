<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product 
    Id="*" 
    Name="Seven Markdown" 
    Language="1033" 
    Version="1.0.0" 
    Manufacturer="Seven Markdown Team" 
    UpgradeCode="{{upgrade_code}}">
    
    <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" />
    
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    
    <MediaTemplate EmbedCab="yes" />
    
    <Feature Id="ProductFeature" Title="Seven Markdown" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>
  </Product>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="Seven Markdown" />
      </Directory>
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="ApplicationFiles">
        <File Id="ApplicationExecutable" Source="$(var.SevenMD.TargetDir)SevenMD.exe" KeyPath="yes" />
        <File Id="ApplicationResources" Source="$(var.SevenMD.TargetDir)*" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>