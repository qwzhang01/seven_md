# Use npm public registry
registry=https://registry.npmjs.org/

# Always save exact version in package-lock.json
save-exact=true

# Don't create package-lock.json for optional dependencies
package-lock-only=false

# Set engine-strict to true to enforce Node.js version
engine-strict=true

# Set to warn instead of error for peer dependencies
legacy-peer-deps=false

# Don't fund packages on install
fund=false

# Don't show progress bar on CI
progress=false
